{
  // Human-readable name shown in the Codespaces UI
  "name": "SystemsDevTeam4",

  // Build the container using the Dockerfile in this directory
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // VS Code extensions installed automatically inside the container
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",          // Python language support
        "ms-python.vscode-pylance",  // Fast type-checking & IntelliSense
        "mtxr.sqliteviewer"          // Browse SQLite databases in the sidebar
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true
      }
    }
  },

  // Install Python dependencies when the container starts
  "postCreateCommand": "pip install -r requirements.txt",

  // Forward no ports by default — add entries here if you add a web server
  "forwardPorts": [],

  // Run as the non-root 'vscode' user for security
  "remoteUser": "vscode"
}
